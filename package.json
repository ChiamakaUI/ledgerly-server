{
  "name": "paid-calendly-server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/app.ts",
    "build": "tsup src/app.ts --format esm --dts",
    "start": "node dist/app.js",
    "migrate": "tsx src/migrations/migrate.ts",
    "typegen": "npx pgtyped -c pgtyped.config.json",
    "test:escrow": "cd integration-test && npx tsx test-escrow-flow.ts"
  },
  "dependencies": {
    "@coral-xyz/anchor": "^0.30.1",
    "@pgtyped/runtime": "^2.4.2",
    "@solana/spl-token": "^0.4.6",
    "@solana/web3.js": "^1.95.3",
    "cors": "^2.8.6",
    "dotenv": "^17.4.0",
    "express": "^5.2.1",
    "nanoid": "^5.0.7",
    "pg": "^8.13.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@pgtyped/cli": "^2.4.3",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/node": "^22.19.17",
    "@types/pg": "^8.11.10",
    "tsup": "^8.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.9.3"
  }
}
